                  name="TableName"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select nm.DebitOrderId as 'Id', nm.DebitOrderType as 'Type', nm.DebiCheckStatus as 'Status', nm.AuthCode as 'AuthKey', nm.BankId as 'Bank',
	   do.DebitOrderId, do.DebitOrderType, do.DebiCheckStatus, do.AuthCode, do.BankId
from DebitOrderNaedoMigration nm
left join DebitOrder do
on do.DebitOrderId = nm.DebitOrderId where do.DebiCheckStatus &lt;&gt; 'NotRequested'
order by do.DebiCheckStatus desc;</property>

          SQLTask:SqlStatementSource="IF OBJECT_ID(N'Omega.dbo.MySql_DebitOrder') IS NOT NULL&#xA;BEGIN&#xA;&#x9;DROP TABLE [dbo].[MySql_DebitOrder]&#xA;END&#xA;&#xA;begin&#xA;CREATE TABLE [dbo].[MySql_DebitOrder] (&#xA;[PersonNo] int NOT NULL,&#xA;[DebitOrderId] int,&#xA;[DebitOrderType] varchar(20),&#xA;[DeductionOccurrence] text NOT NULL,&#xA;[DeductionDay] int NOT NULL,&#xA;[DeductionDate] datetime2 NOT NULL,&#xA;[NowDueFlag] bit NOT NULL,&#xA;[DeductionAmount] decimal(18, 4) NOT NULL,&#xA;[CreateDate] datetime2 NOT NULL&#xA;) &#xA;end" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />

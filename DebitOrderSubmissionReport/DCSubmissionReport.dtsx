            <pipeline
              version="1">
              <components>
                <component
                  refId="Package\Sequence Container\Copy Prod Debit Orders to Omega DEV\DebitOrder"
                  componentClassID="Microsoft.SSISODBCSrc"
                  contactInfo="ODBC Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;1"
                  description="ODBC Source"
                  name="DebitOrder"
                  usesDispositions="true"
                  version="1">
                  <properties>
                    <property
                      dataType="System.String"
                      description="The name of the table to be fetched."
                      expressionType="Notify"
                      name="TableName"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      expressionType="Notify"
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select PersonNo,
       DebitOrderId,
       DebitOrderType,
       DeductionOccurrence,
       DeductionDay,
       DeductionDate,
       NowDueFlag,
       cast(DeductionAmount as decimal(18, 4)) as DeductionAmount,
       CreateDate
from DebitOrder
where Status = 'Active'
and 1 = case
        when DeductionOccurrence = 'Single' and DeductionDate between now() and date_add(now(), INTERVAL 31 DAY) then 1
        when DeductionOccurrence = 'Repeat' then 1
        else 0
        end
and cast(CreateDate as date) &lt; cast(current_date() as date);</property>

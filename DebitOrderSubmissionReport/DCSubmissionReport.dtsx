              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="alter table dbo.MySql_DebitOrder&#xA;alter column DeductionOccurrence varchar(25)&#xA;&#xA;update dbo.MySql_DebitOrder&#xA;set DeductionOccurrence = 'Single' where DeductionOccurrence like '%S%'&#xA;&#xA;update dbo.MySql_DebitOrder&#xA;set DeductionOccurrence = 'Repeat' where DeductionOccurrence like '%R%'" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>

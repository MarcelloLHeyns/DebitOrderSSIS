        <DTS:Executable
          DTS:refId="Package\Sequence Container\Exclude amounts less than R10"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{F5E84198-3ADA-43E8-BD72-18D5812DBB78}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Exclude amounts less than R10"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2A78B467-EE94-4D53-A99D-5EB105877395}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="&#x9;--Exclude amounts less than R10&#xA;&#x9;begin&#xA;&#x9;&#x9;delete dbo.MySql_DebitOrder&#xA;&#x9;&#x9;where DeductionAmount &lt; 10&#xA;&#x9;end" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Exclude repeat customers with no active balance"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{C2A79663-AFD2-4233-B4D0-DACF3FBBBE79}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Exclude repeat customers with no active balance"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2A78B467-EE94-4D53-A99D-5EB105877395}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="&#x9;begin&#xA;&#x9;&#x9;delete do&#xA;&#x9;&#x9;from dbo.MySql_DebitOrder do&#xA;&#x9;&#x9;where cast(do.DeductionOccurrence as varchar) = 'Repeat'&#xA;&#x9;&#x9;and exists (select 1&#xA;&#x9;&#x9;&#x9;from dbo.AccountDetail ad&#xA;&#x9;&#x9;&#x9;where ad.PersonNo = do.PersonNo&#xA;&#x9;&#x9;&#x9;and ad.AcctType = 4&#xA;&#x9;&#x9;&#x9;and ad.BalOuts &lt;= 0)&#xA;&#x9;end" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Fetch now due for NowDue amount records"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{ECECE699-A928-416A-8486-5EB8B9D746D5}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Fetch now due for NowDue amount records"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2A78B467-EE94-4D53-A99D-5EB105877395}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="&#x9;--fetch now due for applicable records&#xA;&#x9;begin&#xA;&#x9;&#x9;update do&#xA;&#x9;&#x9;set DeductionAmount = isnull((select sum(aag.Amt)&#xA;&#x9;&#x9;from dbo.AcctAgeing aag&#xA;&#x9;&#x9;where aag.PersonNo = do.PersonNo&#xA;&#x9;&#x9;&#x9;and aag.AcctType = 4&#xA;&#x9;&#x9;&#x9;and aag.AcctAgeing in (1,2)), 0)&#xA;&#x9;&#x9;&#x9;from dbo.MySql_DebitOrder do&#xA;&#x9;&#x9;&#x9;where do.NowDueFlag = 1&#xA;&#x9;end" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>

                      <outputs>
                        <output
                          refId="Package\Mandate Amend\Naedo Mandate Amend\Get the Naedo Debit Orders Amended after last export\MySQL DebitOrder.Outputs[ADO NET Source Output]"
                          name="ADO NET Source Output">
                          <outputColumns>
                            <outputColumn
                              refId="Package\Mandate Amend\Naedo Mandate Amend\Get the Naedo Debit Orders Amended after last export\MySQL DebitOrder.Outputs[ADO NET Source Output].Columns[DebitOrderId]"
                              dataType="i4"

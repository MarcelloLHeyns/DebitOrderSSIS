                    <component
                      refId="Package\Mandate Amend\Naedo Mandate Amend\Get the Naedo Debit Orders Amended after last export\MySQL DebitOrder"
                      componentClassID="Microsoft.ManagedComponentHost"
                      contactInfo="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;4"
                      description="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server."
                      name="MySQL DebitOrder"
                      usesDispositions="true"
                      version="4">
                      <properties>
                        <property
                          dataType="System.String"
                          description="Specifies the SQL statement used by the component to extract data."
                          expressionType="Notify"
                          name="SqlCommand"
                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select DebitOrderId,  
         PersonNo, 
         BankAccountHolder,
         BankId,BankAccountNumber, 
         BankBranchCode, 
         DeductionAmount, 
         StartYear, 
         StartMonth, 
         DeductionDay, 
		 case when DeductionDate = '0001-01-01 00:00:00.000000' then '1900-01-01 00:00:00.000000' else DeductionDate end as DeductionDate, 
         MandateReceived, 
         Status, 
         BankAccountType, 
         DeductionOccurrence, 
         DeductionFrequency, 
         PaymentAccountType, 
         NaedoType, 
         NowDueFlag, 
         PhoneNumber, 
         Identification, 
         IdentificationType, 
         AuditUser, 
         Department, 
         CreateDate, 
         AuthCode, 
         DebiCheckStatus, 
         DebitOrderType, 
         AuditDate          
         from ( select DebitOrderId, 
					   PersonNo, 
                       BankAccountHolder, 
                       BankId, BankAccountNumber, 
                       BankBranchCode, 
                       DeductionAmount, 
                       StartYear, 
                       StartMonth, 
                       DeductionDay, 
                       case when DeductionDate = '0001-01-01 00:00:00.000000' then '1900-01-01 00:00:00.000000' else DeductionDate end as DeductionDate,
                       MandateReceived, 
                       Status, 
                       BankAccountType, 
                       DeductionOccurrence, 
                       DeductionFrequency, 
                       PaymentAccountType, 
                       NaedoType, 
                       NowDueFlag, 
                       PhoneNumber, 
                       Identification, 
                       IdentificationType, 
                       AuditUser, 
                       Department, 
                       CreateDate, 
                       AuthCode, 
                       DebiCheckStatus, 
                       DebitOrderType, 
                       AuditDate 
				   from DebitOrder 
				  where  DebitOrderType     in ('Naedo')
                     and AuditDate          &gt;= (select ExportDate
												from DebitOrderFileExportAudit
												where ExportAction = 'NaedoAmend'
												order by ExportDate desc
												limit 1)
                     and (Status            in ('Active', 'Cancelled'))  
                     and IdentificationType IS NOT NULL 
                     and AuditUser          != 'svc-debitorder'
                     union 
                     select DebitOrderId, 
                            PersonNo, 
                            BankAccountHolder, 
                            BankId, 
                            BankAccountNumber, 
                            BankBranchCode, 
                            DeductionAmount, 
                            StartYear, 
                            StartMonth,
                            DeductionDay,
                            case when DeductionDate = '0001-01-01 00:00:00.000000' then '1900-01-01 00:00:00.000000' else DeductionDate end as DeductionDate, 
                            MandateReceived, 
                            Status,
                            BankAccountType, 
                            DeductionOccurrence,
                            DeductionFrequency, 
                            PaymentAccountType, 
                            NaedoType, 
                            NowDueFlag, 
                            PhoneNumber, 
                            Identification, 
                            IdentificationType, 
                            AuditUser, 
                            Department, 
                            CreateDate,
                            AuthCode, 
                            DebiCheckStatus, 
                            DebitOrderType, 
                            AuditDate  
						from DebitOrder 
					  where  DebitOrderType                in ('Naedo')
                      and    AuditDate                     &gt;= (select ExportDate
																from DebitOrderFileExportAudit
																where ExportAction = 'NaedoAmend'
																order by ExportDate desc
																limit 1)
                      and    (Status = 'SystemCancelled'   or Status = 'Cancelled')  
                      and    IdentificationType            is not null  
                      and    (AuditUser = 'svc-debitorder' or AuditUser is null))
                      x 
					order by x.AuditDate desc;</property>
                        <property
                          dataType="System.Int32"
                          description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                          name="CommandTimeout">30</property>
                        <property
                          dataType="System.Boolean"
                          description="Indicates whether to allow non-string external columns to be implicitly converted to strings at the output columns."
                          name="AllowImplicitStringConversion">true</property>
                        <property
                          dataType="System.String"
                          description="The Source database table name."
                          expressionType="Notify"
                          name="TableOrViewName"
                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor"></property>
                        <property
                          dataType="System.Int32"
                          description="Specify the mode to retrieve external column information"
                          name="AccessMode"
                          typeConverter="Microsoft.SqlServer.Dts.Pipeline.DataReaderSourceAdapter+EnumToStringConverter">2</property>
                        <property
                          dataType="System.String"
                          name="UserComponentTypeName">Microsoft.DataReaderSourceAdapter</property>
                      </properties>

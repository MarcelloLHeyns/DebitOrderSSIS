        <DTS:Executable
          DTS:refId="Package\Mandate Amend\RMS Mandate Amend"
          DTS:CreationName="STOCK:SEQUENCE"
          DTS:Description="Sequence Container"
          DTS:DTSID="{7c767a8d-9ca5-4b3e-9821-c74dac7c5e08}"
          DTS:ExecutableType="STOCK:SEQUENCE"
          DTS:LocaleID="-1"
          DTS:ObjectName="RMS Mandate Amend">
          <DTS:Variables />
          <DTS:Executables>
            <DTS:Executable
              DTS:refId="Package\Mandate Amend\RMS Mandate Amend\Get all the RMS Debit Orders"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{A3BCEE9F-88B0-4FC3-96E9-D5350330EF31}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Get all the RMS Debit Orders"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
              DTS:ThreadHint="0">
              <DTS:Variables />
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{A832587D-59F1-4BE3-A979-DF99027CB7AA}"
                  SQLTask:SqlStatementSource="  insert into DOMandateRMS&#xA;  (&#xA;  DebitOrderId,&#xA;  ReqAuthDate,&#xA;  Instrument,&#xA;  Bank,&#xA;  AppExport,&#xA;  AuditDate&#xA;  )&#xA;  select &#xA;   DebitOrderId,&#xA;   date(now()),&#xA;   'RMS',&#xA;   'ABSA',&#xA;   0,&#xA;   AuditDate&#xA;    from DebitOrder&#xA;   where DebitOrderType         = 'RMS'&#xA;         and AuditDate          &gt;= (select ExportDate&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;from DebitOrderFileExportAudit&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where ExportAction = 'RMS'&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;order by ExportDate desc&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;limit 1)&#xA;         and IdentificationType is not null&#xA;         and Status             = 'Active' ;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
              </DTS:ObjectData>
            </DTS:Executable>
            <DTS:Executable
              DTS:refId="Package\Mandate Amend\RMS Mandate Amend\Log the Audit date of last RMS Debit Order Exported"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="Execute SQL Task"
              DTS:DTSID="{B6DEF1DE-4F3B-42F6-9541-59DDAAC49E48}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="Log the Audit date of last RMS Debit Order Exported"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
              DTS:ThreadHint="0">
              <DTS:Variables />
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{A832587D-59F1-4BE3-A979-DF99027CB7AA}"
                  SQLTask:SqlStatementSource="CALL `proc_log_rms_export`();" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
              </DTS:ObjectData>
            </DTS:Executable>

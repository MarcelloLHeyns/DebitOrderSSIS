          SQLTask:SqlStatementSource="&#xA;IF OBJECT_ID(N'Omega.[dbo].[BT_Mandates]') IS NOT NULL&#xA;BEGIN&#xA;&#x9;DROP TABLE [dbo].[BT_Mandates]&#xA;END&#xA;&#xA;begin&#xA;CREATE TABLE [dbo].[BT_Mandates](&#xA;&#x9;[Amendment reason code] [nvarchar](255) NULL,&#xA;&#x9;[Cancellation reason code] [nvarchar](255) NULL,&#xA;&#x9;[Mandate ID] [float] NULL,&#xA;&#x9;[Mandate status] [nvarchar](255) NULL,&#xA;&#x9;[Mandate group] [nvarchar](255) NULL,&#xA;&#x9;[Contract reference] [float] NULL,&#xA;&#x9;[Start date] [datetime] NULL,&#xA;&#x9;[End date] [datetime] NULL,&#xA;&#x9;[Occurrence] [nvarchar](255) NULL,&#xA;&#x9;[Frequency] [nvarchar](255) NULL,&#xA;&#x9;[Debit day] [float] NULL,&#xA;&#x9;[Value type] [nvarchar](255) NULL,&#xA;&#x9;[Entry class] [float] NULL,&#xA;&#x9;[Amount] [float] NULL,&#xA;&#x9;[Initial collection amount] [nvarchar](255) NULL,&#xA;&#x9;[Initial collection date] [nvarchar](255) NULL,&#xA;&#x9;[Initial collection reference] [nvarchar](255) NULL,&#xA;&#x9;[First collection amount] [nvarchar](255) NULL,&#xA;&#x9;[First collection date] [nvarchar](255) NULL,&#xA;&#x9;[Max amount] [float] NULL,&#xA;&#x9;[Allow tracking] [bit] NOT NULL,&#xA;&#x9;[Date adjustable] [bit] NOT NULL,&#xA;&#x9;[Adjustment category] [nvarchar](255) NULL,&#xA;&#x9;[Adjustment amount] [float] NULL,&#xA;&#x9;[Adjustment rate] [float] NULL,&#xA;&#x9;[Preapprove collections] [nvarchar](255) NULL,&#xA;&#x9;[DebiCheck key] [nvarchar](255) NULL,&#xA;&#x9;[Preferred service] [nvarchar](255) NULL,&#xA;&#x9;[Mandate instrument] [nvarchar](255) NULL,&#xA;&#x9;[Tracking days] [float] NULL,&#xA;&#x9;[Creditor bank] [nvarchar](255) NULL,&#xA;&#x9;[Creditor account] [float] NULL,&#xA;&#x9;[Short name] [nvarchar](255) NULL,&#xA;&#x9;[Debtor name] [nvarchar](255) NULL,&#xA;&#x9;[Debtor ID] [float] NULL,&#xA;&#x9;[ID type] [nvarchar](255) NULL,&#xA;&#x9;[Account type] [nvarchar](255) NULL,&#xA;&#x9;[Debtor account] [float] NULL,&#xA;&#x9;[Debtor branch] [float] NULL,&#xA;&#x9;[Debtor ema